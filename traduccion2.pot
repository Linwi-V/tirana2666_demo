msgid "⠀⠀⠀⠀Cilantro    $100    x {{inventario[\"cilantro\"][\"cantidad\"]}}⠀⠀⠀⠀"
msgstr ""

#: Dialogues/worlds/World2/EXT/quests/tienda.dialogue
msgid "⠀⠀⠀⠀Ají Verde    $100    x {{inventario[\"aji verde\"][\"cantidad\"]}}⠀⠀⠀⠀"
msgstr ""

#: Dialogues/worlds/World2/EXT/quests/tienda.dialogue
msgid "⠀⠀⠀⠀Merkén    $100    x {{inventario[\"merken\"][\"cantidad\"]}}⠀⠀⠀⠀"
msgstr ""

#: Dialogues/worlds/World2/EXT/quests/tienda.dialogue
msgid "⠀⠀⠀⠀Paprika    $100    x {{inventario[\"paprika\"][\"cantidad\"]}}⠀⠀⠀⠀"
msgstr ""

#: Dialogues/worlds/World2/EXT/quests/tienda.dialogue
msgid "⠀⠀⠀⠀Pimentón    $100    x {{inventario[\"pimenton\"][\"cantidad\"]}}⠀⠀⠀⠀"
msgstr ""

#: Dialogues/worlds/World2/EXT/quests/tienda.dialogue
msgid "⠀⠀⠀⠀Perejil    $100    x {{inventario[\"perejil\"][\"cantidad\"]}}⠀⠀⠀⠀"
msgstr ""

#: Dialogues/worlds/World2/EXT/quests/tienda.dialogue
msgid "⠀⠀⠀⠀Ciboulette    $100    x {{inventario[\"ciboulette\"][\"cantidad\"]}}⠀⠀⠀⠀"
